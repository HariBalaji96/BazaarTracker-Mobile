<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BazaarTrackerMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:statusBarColor">@color/colorPrimaryVariant</item>

        <!-- Shape appearance -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.BazaarTracker.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.BazaarTracker.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.BazaarTracker.Large</item>
    </style>

    <style name="Theme.BazaarTrackerMobile" parent="Base.Theme.BazaarTrackerMobile" />

    <style name="ShapeAppearance.BazaarTracker.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.BazaarTracker.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.BazaarTracker.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

    <style name="Widget.BazaarTracker.Button" parent="Widget.Material3.Button">
        <item name="shapeAppearance">@style/ShapeAppearance.BazaarTracker.Medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="Widget.BazaarTracker.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/surface_light</item>
    </style>
</resources>